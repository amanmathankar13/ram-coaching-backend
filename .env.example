# ── Server ──────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── MongoDB ──────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/ramcoaching
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/ramcoaching

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# ── Email (Nodemailer) ───────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=info@ramcoaching.in
EMAIL_PASS=your_app_password
EMAIL_FROM="Ram Coaching Classes <info@ramcoaching.in>"
ADMIN_EMAIL=admin@ramcoaching.in
